rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Golf Paper Craft asset browser — public read, admin-only write.
    // All writes go through Vercel API routes using Firebase Admin SDK (bypasses rules).
    match /golf-paper-craft/{doc} {
      allow read: if true;
      allow write: if false;
    }
    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
